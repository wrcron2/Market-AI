# =============================================================================
# MarketFlow AI — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# --- Interactive Brokers (IBKR) ---
# Keep these on local hardware only. Never send to cloud.
IBKR_HOST=127.0.0.1
IBKR_PORT=7497           # 7497 = paper trading, 7496 = live
IBKR_CLIENT_ID=1
IBKR_ACCOUNT_ID=         # Your IBKR account number

# --- Go Backend ---
GO_SERVER_PORT=8080
GO_GRPC_PORT=50051
GO_WS_PORT=8081

# --- Database (staged orders) ---
# SQLite for local dev; swap for Postgres in prod
DB_DRIVER=sqlite
DB_DSN=./infra/db/marketflow.db
# For Postgres: DB_DSN=postgres://user:pass@localhost:5432/marketflow?sslmode=disable

# --- Python AI Brain ---
BRAIN_GRPC_PORT=50052
BRAIN_HOST=127.0.0.1

# --- Ollama (local, low-complexity tasks) ---
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# --- AWS Bedrock (heavy reasoning) ---
# Uses standard AWS credential chain — set these OR use ~/.aws/credentials
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=global.anthropic.claude-sonnet-4-6

# --- Feature Flags ---
# Set to "true" to enable paper trading safety mode (no real orders)
PAPER_TRADING=true
# Minimum confidence score (0.0–1.0) required before staging an order
MIN_SIGNAL_CONFIDENCE=0.90

# --- Trading Mode (controlled by dashboard toggle) ---
# "yahoo" = yfinance simulation (no API key needed, no real money)
# "ibkr"  = live trading via IBKR (Green Light gate still enforced)
# Note: the React dashboard toggle overrides this at runtime via /api/mode
TRADING_MODE=yahoo

# --- Yahoo Finance Simulation Settings ---
# Virtual starting cash for the simulated portfolio
SIM_INITIAL_CASH=100000
# Slippage model: basis points per fill (5bps = 0.05% — realistic for mid-caps)
SIM_SLIPPAGE_BPS=5
# Max position size (shares) in simulation mode
RISK_MAX_QUANTITY=10000
